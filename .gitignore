/nvim/lazy-lock.json

/yazi/state
/yazi/config/*
!/yazi/config/init.lua
!/yazi/config/keymap.toml
!/yazi/config/package.toml
!/yazi/config/theme.toml
!/yazi/config/yazi.toml

/lazygit/state.yml

